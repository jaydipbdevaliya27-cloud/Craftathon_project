<%- include('../partials/header') %>
<%- include('../partials/navbar') %>
<main class="main-content">
  <div class="page-header">
    <div>
      <h1 class="page-title"><%= asset.name %></h1>
      <p class="page-subtitle">Asset ID: <%= asset.assetId %></p>
    </div>
    <div class="header-actions">
      <a href="/assets" class="btn btn-ghost">← BACK</a>
      <% if (user && (user.role === 'admin' || user.role === 'officer')) { %>
        <form action="/assets/<%= asset._id %>/delete" method="POST" onsubmit="return confirm('Delete this asset?');" style="display:inline">
          <button type="submit" class="btn btn-danger">DELETE</button>
        </form>
      <% } %>
    </div>
  </div>

  <div class="detail-grid">
    <!-- Primary Specifications Card -->
    <div class="card detail-card shadow-lg">
      <div class="card-header">
        <h2 class="card-title">TECHNICAL SPECIFICATIONS</h2>
      </div>
      <div class="card-body">
        <div class="detail-row">
          <span class="detail-label">Asset Name</span>
          <span class="detail-value text-primary"><%= asset.name %></span>
        </div>
        <div class="detail-row">
          <span class="detail-label">Category</span>
          <span class="badge badge-info"><%= asset.category %></span>
        </div>
        <div class="detail-row">
          <span class="detail-label">Serial Number</span>
          <code class="asset-id"><%= asset.serialNumber || '—' %></code>
        </div>
        <div class="detail-row">
          <span class="detail-label">Current Status</span>
          <span class="status-badge status-<%= asset.status ? asset.status.toLowerCase().replace(/ /g,'-') : 'unknown' %>">
            <%= asset.status || 'N/A' %>
          </span>
        </div>
        <div class="detail-row">
          <span class="detail-label">Combat Condition</span>
          <span class="detail-value condition-<%= asset.condition ? asset.condition.toLowerCase() : 'unknown' %>">
            <%= asset.condition || 'N/A' %>
          </span>
        </div>
        <div class="detail-row">
          <span class="detail-label">Stationed At</span>
          <span class="detail-value"><%= asset.location %></span>
        </div>
        <div class="detail-row">
          <span class="detail-label">Assigned Unit</span>
          <span class="detail-value"><%= asset.unit || 'Standard Issue' %></span>
        </div>
        <div class="detail-row">
          <span class="detail-label">Manufacturer</span>
          <span class="detail-value"><%= asset.manufacturer || 'General Ordnance' %></span>
        </div>
        <div class="detail-row">
          <span class="detail-label">Acquisition Date</span>
          <span class="detail-value"><%= new Date(asset.acquisitionDate).toLocaleDateString() %></span>
        </div>
        <div class="detail-row">
          <span class="detail-label">Assigned Personnel</span>
          <span class="detail-value">
            <% if (asset.assignedTo) { %>
              <%= asset.assignedTo.username %> <%= asset.assignedTo.rank ? '(' + asset.assignedTo.rank + ')' : '' %>
            <% } else { %>
              <span class="text-muted">Unassigned (Armoury)</span>
            <% } %>
          </span>
        </div>

        <%# ---- CHECKOUT USAGE METER ---- %>
        <% if (asset.maxCheckout > 0) { %>
        <div class="detail-row-block mt-4" style="border-top: 2px dashed var(--border); padding-top: 1rem;">
          <span class="detail-label" style="margin-bottom: 0.5rem; display: block;">
            USAGE METER 
            <% if (asset.checkoutLimitTriggered) { %><span style="color: var(--red); font-size: 0.7rem;">⚠ LIMIT REACHED</span><% } %>
          </span>
          <div style="display: flex; align-items: center; gap: 1rem;">
            <div style="flex: 1; background: var(--bg-secondary); border-radius: 8px; height: 12px; overflow: hidden;">
              <div style="width: <%= Math.min((asset.checkoutCount / asset.maxCheckout) * 100, 100).toFixed(0) %>%; height: 100%; background: <%= (asset.checkoutCount >= asset.maxCheckout) ? 'var(--red)' : (asset.checkoutCount / asset.maxCheckout > 0.75 ? 'var(--yellow)' : 'var(--green)') %>; border-radius: 8px; transition: width 0.5s;"></div>
            </div>
            <span style="font-weight: 700; font-size: 0.85rem; white-space: nowrap;">
              <%= asset.checkoutCount %> / <%= asset.maxCheckout %> uses
            </span>
          </div>
        </div>
        <% } else { %>
        <div class="detail-row">
          <span class="detail-label">Checkout Count</span>
          <span class="detail-value"><%= asset.checkoutCount || 0 %> uses <span class="text-muted">(no limit set)</span></span>
        </div>
        <% } %>
        
        <% if (asset.description) { %>
          <div class="detail-row-block mt-4">
            <span class="detail-label">Technical Notes</span>
            <p class="detail-value"><%= asset.description %></p>
          </div>
        <% } %>
      </div>
    </div>

    <div class="side-panel">
      <!-- Admin Controls Card -->
      <% if (user && (user.role === 'admin' || user.role === 'officer' || user.role === 'technician')) { %>
        <div class="card detail-card mb-4 border-primary">
          <div class="card-header bg-soft-primary">
            <h2 class="card-title">OPERATIONAL UPDATE</h2>
          </div>
          <div class="card-body">
            <form action="/assets/<%= asset._id %>/update?_method=PUT" method="POST">
              <div class="form-group mb-3">
                <label>DEPLOYMENT STATUS</label>
                <select name="status" class="form-control">
                  <% ['Available', 'In Use', 'Under Maintenance', 'Decommissioned', 'Lost'].forEach(s => { %>
                    <option value="<%= s %>" <%= asset.status === s ? 'selected' : '' %>><%= s %></option>
                  <% }) %>
                </select>
              </div>
              <div class="form-group mb-3">
                <label>FIELD CONDITION</label>
                <select name="condition" class="form-control">
                  <% ['Excellent', 'Good', 'Fair', 'Poor'].forEach(c => { %>
                    <option value="<%= c %>" <%= asset.condition === c ? 'selected' : '' %>><%= c %></option>
                  <% }) %>
                </select>
              </div>
              <div class="form-group mb-3">
                <label>CURRENT LOCATION</label>
                <input type="text" name="location" class="form-control" value="<%= asset.location %>" />
              </div>
              <div class="form-group mb-3">
                <label>MAINTENANCE LOGS</label>
                <textarea name="notes" class="form-control" rows="3" placeholder="Append operational notes..."><%= asset.notes || '' %></textarea>
              </div>
              <button type="submit" class="btn btn-primary btn-full shadow">APPLY CHANGES</button>
            </form>
          </div>
        </div>
      <% } %>

      <!-- Identification Card -->
      <% if (asset.qrCode) { %>
        <div class="card detail-card border-light">
          <div class="card-header">
            <h2 class="card-title">ASSET IDENTIFICATION</h2>
          </div>
          <div class="card-body qr-container">
            <div class="qr-image-wrapper">
              <img src="<%= asset.qrCode %>" alt="QR Code" class="qr-image" />
            </div>
            <p class="text-center text-muted small">Scan for rapid field identification and digital log access.</p>
          </div>
        </div>
      <% } %>
    </div>
  </div>
</main>
<%- include('../partials/footer') %>
