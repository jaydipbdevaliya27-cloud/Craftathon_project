<%- include('../partials/header') %>
  <%- include('../partials/navbar') %>
    <main class="main-content">
      <div class="page-header">
        <div>
          <h1 class="page-title">ASSET REGISTRY</h1>
          <p class="page-subtitle">All tracked defence equipment</p>
        </div>
        <% if (user && (user.role==='admin' || user.role==='officer' )) { %>
          <a href="/assets/add" class="btn btn-primary">+ ADD ASSET</a>
          <% } %>
      </div>

      <!-- Quick Stats (always global, not filtered) -->
      <% if (filters.status || filters.category || filters.search) { %>
      <div style="display: flex; align-items: center; gap: 0.5rem; padding: 0.6rem 1rem; background: var(--primary-soft); border: 1px solid var(--primary); border-radius: 8px; margin-bottom: 1rem; font-size: 0.85rem; color: var(--primary);">
        <span>🔍</span>
        <strong>FILTER ACTIVE</strong> — showing <%= assets.length %> filtered result(s). Stats below reflect <strong>full fleet totals</strong>.
      </div>
      <% } %>
      <div class="stats-grid mb-4">
        <div class="stat-card stat-total">
          <div class="stat-icon" style="background: var(--blue-soft); color: var(--blue);">📦</div>
          <div class="stat-info">
            <div class="stat-value"><%= stats.totalAssets %></div>
            <div class="stat-label">TOTAL ASSETS</div>
          </div>
        </div>
        <div class="stat-card stat-available">
          <div class="stat-icon" style="background: var(--green-soft); color: var(--green);">✅</div>
          <div class="stat-info">
            <div class="stat-value"><%= stats.availableAssets %></div>
            <div class="stat-label">AVAILABLE</div>
          </div>
        </div>
        <div class="stat-card stat-inuse">
          <div class="stat-icon" style="background: var(--primary-soft); color: var(--primary);">🔫</div>
          <div class="stat-info">
            <div class="stat-value"><%= stats.inUseAssets %></div>
            <div class="stat-label">ISSUED / IN USE</div>
          </div>
        </div>
        <div class="stat-card stat-maintenance">
          <div class="stat-icon" style="background: var(--yellow-soft); color: var(--yellow);">🛠️</div>
          <div class="stat-info">
            <div class="stat-value"><%= stats.maintenanceAssets %></div>
            <div class="stat-label">MAINTENANCE</div>
          </div>
        </div>
        <div class="stat-card stat-pending">
          <div class="stat-icon" style="background: var(--red-soft); color: var(--red);">🗄️</div>
          <div class="stat-info">
            <div class="stat-value"><%= stats.decommissionedAssets %></div>
            <div class="stat-label">DECOMMISSIONED</div>
          </div>
        </div>
      </div>

      <!-- Unified Filter System -->
      <div class="filter-bar">
        <form method="GET" action="/assets" class="filter-form">
          <div class="form-group mb-0" style="flex: 1.5;">
            <label>SEARCH INVENTORY</label>
            <input type="text" name="search" class="form-control" placeholder="Weapon ID or keyword..."
              value="<%= filters.search || '' %>" />
          </div>
          <div class="form-group mb-0">
            <label>DEPLOYMENT STATUS</label>
            <select name="status" class="form-control">
              <option value="">All Statuses</option>
              <% statuses.forEach(s=> { %><option value="<%= s %>" <%=filters.status===s ? 'selected' : '' %>><%= s %>
                </option>
                <% }) %>
            </select>
          </div>
          <div class="form-group mb-0">
            <label>CATEGORY</label>
            <select name="category" class="form-control">
              <option value="">All Categories</option>
              <% categories.forEach(c=> { %><option value="<%= c %>" <%=filters.category===c ? 'selected' : '' %>><%= c
                    %>
                </option>
                <% }) %>
            </select>
          </div>
          <button type="submit" class="btn btn-primary btn-sm mt-3">FILTER</button>
          <a href="/assets" class="btn btn-outline btn-sm mt-3">CLEAR</a>
        </form>
      </div>

      <!-- Asset Table -->
      <div class="card">
        <div class="card-body p-0">
          <% if (assets.length===0) { %>
            <div style="text-align: center; padding: 4rem 2rem; opacity: 0.7;">
              <div style="font-size: 3rem; margin-bottom: 1rem;">📦</div>
              <p>No assets found. <a href="/assets/add" style="color: var(--primary); font-weight: 700;">Add the first
                  asset.</a></p>
            </div>
            <% } else { %>
              <div class="table-container">
                <table class="table">
                  <thead>
                    <tr>
                      <th>SERIAL NO</th>
                      <th>NAME</th>
                      <th>STATUS</th>
                      <th>CONDITION</th>
                      <th>LOCATION</th>
                      <th>ASSIGNED TO</th>
                      <th>ACTIONS</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% assets.forEach(asset=> { %>
                      <tr data-status="<%= asset.status %>">
                        <td><code class="asset-id"><%= asset.serialNumber %></code></td>
                        <td><strong>
                            <%= asset.name %>
                          </strong><br /><small class="text-secondary">
                            <%= asset.category %>
                          </small></td>
                        <td><span
                            class="status-badge status-<%= asset.status ? asset.status.toLowerCase().replace(/ /g,'-') : 'unknown' %>">
                            <%= asset.status || 'N/A' %>
                          </span></td>
                        <td><span class="condition-<%= asset.condition ? asset.condition.toLowerCase() : 'unknown' %>"
                            style="font-weight: 700;">
                            <%= asset.condition || 'N/A' %>
                          </span></td>
                        <td><span class="text-secondary">
                            <%= asset.location %>
                          </span></td>
                        <td>
                          <% if (asset.assignedTo) { %>
                            <div class="user-info">
                              <span class="user-avatar" style="width: 28px; height: 28px; font-size: 0.75rem;">
                                <%= asset.assignedTo.username.charAt(0).toUpperCase() %>
                              </span>
                              <div>
                                <span class="user-name">
                                  <%= asset.assignedTo.name || asset.assignedTo.username %>
                                </span>
                                <span class="user-role">
                                  <%= asset.assignedTo.rank || 'Soldier' %>
                                </span>
                              </div>
                            </div>
                            <% } else { %>
                              <span class="text-muted">—</span>
                              <% } %>
                        </td>
                        <td>
                          <a href="/assets/<%= asset._id %>" class="btn btn-xs btn-outline">VIEW</a>
                        </td>
                      </tr>
                      <% }) %>
                  </tbody>
                </table>
              </div>
              <% } %>
        </div>
      </div>
    </main>

    <script>
      function filterByTab(evt, status) {
        // Update tab UI
        const tabs = document.getElementsByClassName("tab-link");
        for (let i = 0; i < tabs.length; i++) {
          tabs[i].classList.remove("active");
        }
        evt.currentTarget.classList.add("active");

        // Filter table rows
        const rows = document.querySelectorAll("tbody tr");
        rows.forEach(row => {
          const rowStatus = row.getAttribute("data-status");
          if (status === 'all' || rowStatus === status) {
            row.style.display = "";
          } else {
            row.style.display = "none";
          }
        });

        // Update empty state if needed
        const visibleRows = Array.from(rows).filter(r => r.style.display !== "none").length;
        let emptyMsg = document.getElementById("empty-tab-msg");
        if (visibleRows === 0) {
          if (!emptyMsg) {
            emptyMsg = document.createElement("div");
            emptyMsg.id = "empty-tab-msg";
            emptyMsg.className = "empty-state";
            emptyMsg.innerHTML = `<div class="empty-icon">📂</div><p>No assets found in this category.</p>`;
            document.querySelector(".card-body").appendChild(emptyMsg);
          }
        } else if (emptyMsg) {
          emptyMsg.remove();
        }
      }
    </script>
    <%- include('../partials/footer') %>