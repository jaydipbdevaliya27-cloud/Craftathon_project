<%- include('../partials/header') %>
<%- include('../partials/navbar') %>
<main class="main-content">
  <div class="page-header">
    <div>
      <h1 class="page-title">MAINTENANCE SCHEDULE</h1>
      <p class="page-subtitle">Equipment service and repair tracking</p>
    </div>
    <% if (user && (user.role === 'admin' || user.role === 'officer' || user.role === 'technician')) { %>
      <button class="btn btn-primary" onclick="document.getElementById('mntModal').style.display='flex'">+ SCHEDULE</button>
    <% } %>
  </div>

  <div class="filter-bar">
    <form method="GET" action="/maintenance" class="filter-form">
      <select name="status" class="form-control">
        <option value="">All Status</option>
        <% statuses.forEach(s => { %><option value="<%= s %>" <%= filters.status===s?'selected':'' %>><%= s %></option><% }) %>
      </select>
      <select name="priority" class="form-control">
        <option value="">All Priority</option>
        <% priorities.forEach(p => { %><option value="<%= p %>" <%= filters.priority===p?'selected':'' %>><%= p %></option><% }) %>
      </select>
      <button type="submit" class="btn btn-outline">FILTER</button>
      <a href="/maintenance" class="btn btn-ghost">CLEAR</a>
    </form>
  </div>

  <div class="card">
    <div class="card-body p-0">
      <% if (records.length === 0) { %>
        <div class="empty-state"><div class="empty-icon">🛠️</div><p>No maintenance records found.</p></div>
      <% } else { %>
        <table class="table table-hover">
          <thead>
            <tr><th>ID</th><th>ASSET</th><th>TYPE</th><th>PRIORITY</th><th>STATUS</th><th>SCHEDULED</th><th>TECHNICIAN</th><th>ACTIONS</th></tr>
          </thead>
          <tbody>
            <% records.forEach(r => { %>
              <tr>
                <td><code class="asset-id"><%= r.maintenanceId %></code></td>
                <td><%= r.asset ? r.asset.name : 'N/A' %></td>
                <td><span class="badge badge-type"><%= r.type %></span></td>
                <td><span class="priority-badge priority-<%= r.priority.toLowerCase() %>"><%= r.priority %></span></td>
                <td><span class="status-badge status-<%= r.status.toLowerCase().replace(/ /g,'-') %>"><%= r.status %></span></td>
                <td><%= new Date(r.scheduledDate).toLocaleDateString() %></td>
                <td><%= r.assignedTechnician ? r.assignedTechnician.username : '—' %></td>
                <td>
                  <% if (r.status !== 'Completed' && r.status !== 'Cancelled' && user && (user.role === 'admin' || user.role === 'technician')) { %>
                    <button class="btn btn-xs btn-success" onclick="openComplete('<%= r._id %>')">COMPLETE</button>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </div>
  </div>
</main>

<!-- Schedule Maintenance Modal -->
<div id="mntModal" class="modal-overlay" style="display:none;" onclick="if(event.target===this) this.style.display='none'">
  <div class="modal">
    <div class="modal-header">
      <h2>SCHEDULE MAINTENANCE</h2>
      <button onclick="document.getElementById('mntModal').style.display='none'" class="modal-close">✕</button>
    </div>
    <form action="/maintenance/create" method="POST" class="modal-body">
      <div class="form-group">
        <label>ASSET ID</label>
        <input type="text" name="assetId" class="form-control" placeholder="MongoDB Asset _id" required />
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>TYPE</label>
          <select name="type" class="form-control" required>
            <option value="Routine">Routine</option>
            <option value="Repair">Repair</option>
            <option value="Inspection">Inspection</option>
            <option value="Overhaul">Overhaul</option>
            <option value="Emergency">Emergency</option>
          </select>
        </div>
        <div class="form-group">
          <label>PRIORITY</label>
          <select name="priority" class="form-control">
            <% priorities.forEach(p => { %><option value="<%= p %>"><%= p %></option><% }) %>
          </select>
        </div>
      </div>
      <div class="form-group">
        <label>SCHEDULED DATE</label>
        <input type="date" name="scheduledDate" class="form-control" required />
      </div>
      <div class="form-group">
        <label>DESCRIPTION</label>
        <textarea name="description" class="form-control" rows="2" placeholder="Maintenance details..."></textarea>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>TECHNICIAN ID (optional)</label>
          <input type="text" name="technicianId" class="form-control" placeholder="User _id" />
        </div>
        <div class="form-group">
          <label>ESTIMATED COST (₹)</label>
          <input type="number" name="cost" class="form-control" placeholder="0" min="0" />
        </div>
      </div>
      <div class="form-actions">
        <button type="button" onclick="document.getElementById('mntModal').style.display='none'" class="btn btn-ghost">CANCEL</button>
        <button type="submit" class="btn btn-primary">SCHEDULE</button>
      </div>
    </form>
  </div>
</div>

<!-- Complete Maintenance Modal -->
<div id="completeModal" class="modal-overlay" style="display:none;" onclick="if(event.target===this) this.style.display='none'">
  <div class="modal">
    <div class="modal-header">
      <h2>COMPLETE MAINTENANCE</h2>
      <button onclick="document.getElementById('completeModal').style.display='none'" class="modal-close">✕</button>
    </div>
    <form id="completeForm" action="" method="POST" class="modal-body">
      <div class="form-group">
        <label>NOTES</label>
        <textarea name="notes" class="form-control" rows="3" placeholder="Completion notes..."></textarea>
      </div>
      <div class="form-group">
        <label>PARTS REPLACED (comma-separated)</label>
        <input type="text" name="partsReplaced" class="form-control" placeholder="e.g. Barrel, Spring" />
      </div>
      <div class="form-group">
        <label>ACTUAL COST (₹)</label>
        <input type="number" name="cost" class="form-control" placeholder="0" min="0" />
      </div>
      <div class="form-actions">
        <button type="button" onclick="document.getElementById('completeModal').style.display='none'" class="btn btn-ghost">CANCEL</button>
        <button type="submit" class="btn btn-success">MARK COMPLETE</button>
      </div>
    </form>
  </div>
</div>
<script>
function openComplete(id) {
  document.getElementById('completeForm').action = '/maintenance/' + id + '/complete';
  document.getElementById('completeModal').style.display = 'flex';
}
</script>
<%- include('../partials/footer') %>
