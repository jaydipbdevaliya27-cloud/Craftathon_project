<%- include('../partials/header') %>
<%- include('../partials/navbar') %>
<main class="main-content">
  <div class="page-header">
    <h1 class="page-title">COMMAND DASHBOARD</h1>
    <p class="page-subtitle">Overview of Defence Asset Status</p>
  </div>

  <%# ---- CHECKOUT LIMIT ALERT PANEL ---- %>
  <% if (checkoutAlerts && checkoutAlerts.length > 0) { %>
  <div class="alert-panel" style="background: #fffbeb; border: 2px solid #f59e0b; border-radius: 12px; padding: 1.25rem 1.75rem; margin-bottom: 2rem;">
    <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1rem;">
      <span style="font-size: 1.5rem;">⚠️</span>
      <div>
        <h3 style="margin: 0; font-size: 1rem; font-weight: 800; color: #92400e; text-transform: uppercase; letter-spacing: 1px;">CHECKOUT LIMIT ALERTS</h3>
        <p style="margin: 0; color: #b45309; font-size: 0.85rem;"><%= checkoutAlerts.length %> asset(s) have reached their maximum checkout limit and are scheduled for mandatory maintenance.</p>
      </div>
      <a href="/maintenance" class="btn btn-sm" style="margin-left: auto; background: #f59e0b; color: white;">VIEW MAINTENANCE</a>
    </div>
    <table class="table" style="background: white; border-radius: 8px; overflow: hidden;">
      <thead>
        <tr>
          <th>WEAPON</th>
          <th>SERIAL NO</th>
          <th>CHECKOUTS</th>
          <th>MAX LIMIT</th>
          <th>STATUS</th>
        </tr>
      </thead>
      <tbody>
        <% checkoutAlerts.forEach(a => { %>
        <tr>
          <td><strong><%= a.name %></strong></td>
          <td><code class="asset-id"><%= a.serialNumber %></code></td>
          <td><span style="font-weight: 800; color: #d97706;"><%= a.checkoutCount %></span></td>
          <td><%= a.maxCheckout %></td>
          <td><span class="status-badge status-under-maintenance"><%= a.status %></span></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <% } %>

  <!-- Stats Grid -->
  <div class="stats-grid">
    <div class="stat-card stat-total">
      <div class="stat-icon">📦</div>
      <div class="stat-info">
        <div class="stat-value"><%= stats.totalAssets %></div>
        <div class="stat-label">TOTAL ASSETS</div>
      </div>
    </div>
    <div class="stat-card stat-available">
      <div class="stat-icon">✅</div>
      <div class="stat-info">
        <div class="stat-value"><%= stats.availableAssets %></div>
        <div class="stat-label">AVAILABLE</div>
      </div>
    </div>
    <div class="stat-card stat-inuse">
      <div class="stat-icon">🔄</div>
      <div class="stat-info">
        <div class="stat-value"><%= stats.inUseAssets %></div>
        <div class="stat-label">IN USE</div>
      </div>
    </div>
    <div class="stat-card stat-maintenance">
      <div class="stat-icon">🛠️</div>
      <div class="stat-info">
        <div class="stat-value"><%= stats.maintenanceAssets %></div>
        <div class="stat-label">MAINTENANCE</div>
      </div>
    </div>
    <div class="stat-card stat-pending">
      <div class="stat-icon">⏳</div>
      <div class="stat-info">
        <div class="stat-value"><%= stats.maintenanceDue %></div>
        <div class="stat-label">PENDING TASKS</div>
      </div>
    </div>
  </div>

  <!-- Dashboard Grid -->
  <div class="dashboard-grid">
    <!-- Recent Transactions -->
    <div class="card">
      <div class="card-header">
        <h2 class="card-title">RECENT TRANSACTIONS</h2>
        <a href="/transactions" class="btn btn-sm btn-outline">VIEW ALL</a>
      </div>
      <div class="card-body">
        <% if (recentTransactions.length === 0) { %>
          <p class="empty-msg">No transactions yet.</p>
        <% } else { %>
          <table class="table">
            <thead>
              <tr><th>TYPE</th><th>ASSET</th><th>TO</th><th>DATE</th></tr>
            </thead>
            <tbody>
              <% recentTransactions.forEach(txn => { %>
                <tr>
                  <td><span class="badge badge-<%= txn.type ? txn.type.toLowerCase() : 'unknown' %>"><%= txn.type || 'N/A' %></span></td>
                  <td><%= txn.asset ? txn.asset.name : 'N/A' %></td>
                  <td><%= txn.toUser ? txn.toUser.username : '—' %></td>
                  <td><%= new Date(txn.createdAt).toLocaleDateString() %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        <% } %>
      </div>
    </div>

    <!-- Activity Log -->
    <div class="card">
      <div class="card-header">
        <h2 class="card-title">RECENT ACTIVITY</h2>
        <a href="/audit" class="btn btn-sm btn-outline">VIEW LOG</a>
      </div>
      <div class="card-body p-0">
        <% if (recentLogs.length === 0) { %>
          <p class="empty-msg" style="padding: 1.5rem;">No activity recorded.</p>
        <% } else { %>
          <div class="table-container">
            <table class="table">
              <thead>
                <tr>
                  <th>ACTION</th>
                  <th>PERFORMED BY</th>
                  <th>TIME</th>
                </tr>
              </thead>
              <tbody>
                <% recentLogs.forEach(log => { %>
                  <tr>
                    <td><strong><%= log.action %></strong></td>
                    <td><%= log.performedBy ? log.performedBy.username : 'Unknown' %></td>
                    <td><small class="text-muted"><%= new Date(log.timestamp).toLocaleString() %></small></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>

    <!-- Asset Categories -->
    <div class="card">
      <div class="card-header">
        <h2 class="card-title">ASSETS BY CATEGORY</h2>
      </div>
      <div class="card-body">
        <% if (byCategory.length === 0) { %>
          <p class="empty-msg">No assets found.</p>
        <% } else { %>
          <div class="category-bars">
            <% const maxCount = Math.max(...byCategory.map(c => c.count), 1); %>
            <% byCategory.forEach(cat => { %>
              <div class="category-bar-item">
                <span class="category-name"><%= cat._id %></span>
                <div class="bar-bg">
                  <div class="bar-fill" style="width: <%= (cat.count/maxCount*100).toFixed(0) + '%' %>"></div>
                </div>
                <span class="category-count"><%= cat.count %></span>
              </div>
            <% }) %>
          </div>
        <% } %>
      </div>
    </div>

    <!-- Quick Actions -->
    <div class="card">
      <div class="card-header">
        <h2 class="card-title">QUICK ACTIONS</h2>
      </div>
      <div class="card-body quick-actions">
        <a href="/assets/add" class="action-btn">
          <span class="action-icon">➕</span>
          <span>Add Asset</span>
        </a>
        <a href="/transactions" class="action-btn">
          <span class="action-icon">📤</span>
          <span>Issue Asset</span>
        </a>
        <a href="/maintenance" class="action-btn">
          <span class="action-icon">🛠️</span>
          <span>Schedule Maintenance</span>
        </a>
        <a href="/audit" class="action-btn">
          <span class="action-icon">📋</span>
          <span>View Audit Log</span>
        </a>
      </div>
    </div>
  </div>
</main>
<%- include('../partials/footer') %>
