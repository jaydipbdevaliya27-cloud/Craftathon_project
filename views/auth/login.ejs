<%- include('../partials/header') %>
<div class="auth-page">
  <div class="auth-card">
    <span class="auth-logo">🛡️</span>
    <h1 class="auth-title">DEFENCETRACK</h1>
    <p class="auth-subtitle">Secure Asset Command & Accountability</p>
    
    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>
    <% if (success) { %>
      <div class="alert alert-success"><%= success %></div>
    <% } %>

    <form action="/auth/login" method="POST" class="auth-form">
      <div class="form-group">
        <label for="username">USERNAME</label>
        <input type="text" id="username" name="username" class="form-control" placeholder="Service Number / Username" required />
      </div>
      <div class="form-group">
        <label for="password">PASSWORD</label>
        <input type="password" id="password" name="password" class="form-control" placeholder="••••••••" required />
      </div>
      <div class="form-group">
        <label for="role">ROLE</label>
        <select id="role" name="role" class="form-control" required>
          <option value="soldier">Soldier</option>
          <option value="officer">Officer</option>
          <option value="technician">Technician</option>
          <option value="admin">Administrator</option>
        </select>
      </div>
      <button type="submit" class="btn btn-primary btn-full">AUTHENTICATE</button>
    </form>
    
    <div class="auth-footer">
      No account? <a href="/auth/register">Register Personnel</a>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
