<% const allLinks=[ { href: '/dashboard' , label: 'Dashboard' , icon: '🏠' , roles: ['admin', 'officer' , 'soldier'
  , 'viewer' ] }, { href: '/technician/dashboard' , label: 'Tasks' , icon: '🔧' , roles: ['technician'] }, {
  href: '/assets' , label: 'Assets' , icon: '📦' , roles: ['admin', 'officer' , 'viewer' ] }, {
  href: '/assets/custody-history' , label: 'History' , icon: '📜' , roles: ['admin', 'officer' ] }, {
  href: '/transactions' , label: 'Transactions' , icon: '🔄' , roles: ['admin', 'officer' ] }, { href: '/maintenance' ,
  label: 'Maintenance' , icon: '🛠️' , roles: ['admin', 'officer' ] }, { href: '/audit' , label: 'Audit' , icon: '📋' ,
  roles: ['admin'] }, { href: '/technician/history' , label: 'History' , icon: '📁' , roles: ['technician'] }, ]; const
  navLinks=allLinks.filter(link=> link.roles.includes(user ? user.role : 'viewer'));
  %>
  <nav class="navbar">
    <div class="nav-brand">
      <span class="nav-logo" style="color: var(--primary);">🛡️</span>
      <span class="nav-title">DEFENCETRACK</span>
    </div>
    <ul class="nav-links">
      <% navLinks.forEach(link=> { %>
        <li>
          <% let isActive=false; if (currentPath) { isActive=(currentPath===link.href) || (link.href !=='/dashboard' &&
            link.href !=='/technician/dashboard' && currentPath.startsWith(link.href)); } %>
            <a href="<%= link.href %>" class="nav-link <%= isActive ? 'active' : '' %>">
              <span class="nav-icon">
                <%= link.icon %>
              </span>
              <span>
                <%= link.label %>
              </span>
            </a>
        </li>
        <% }) %>
    </ul>
    <div class="nav-user">
      <% if (user) { %>
        <div class="user-info">
          <span class="user-avatar">
            <%= user.username[0].toUpperCase() %>
          </span>
          <div class="user-details">
            <span class="user-role badge-<%= user.role %>">
              <%= user.role.toUpperCase() %>
            </span>
          </div>
        </div>
        <form action="/auth/logout" method="POST" class="logout-form">
          <button type="submit" class="btn-logout">LOGOUT</button>
        </form>
        <% } %>
    </div>
  </nav>